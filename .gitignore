# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenv
.venv/
venv/

# Env files
.env
.env.local

# OS
.DS_Store

# Editor
.vscode/
.idea/

# Claude Code session state (rules/ stays tracked; ephemeral state does not)
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/projects/
.claude/worktrees/

# Fetch.ai uAgent local keystore — never commit
private_keys.json

# Local pre-overhaul backups of frontend files
frontend/_archive/

# Data — NEVER commit the feed snapshot or the regulation map data dumps.
# Directory contents are ignored with a glob (not `data/`) so that
# re-inclusions below actually work — with a directory-level ignore
# Git refuses to descend and !data/foo.json has no effect.
data/*
*.zip
*.tar.gz
!/feed.tar.gz
data_railway/
# … but the tiny curated JSON metadata IS version-controlled — the
# API reads it at startup and the Dockerfile bakes it into the image.
!data/corridors.json
!data/railcard_display.json
!data/cluster_labels.json
!data/classification_corridor.json
!data/easement_predicates.json
!data/carbon_oracle_template.json

# Personal planning + scratch experiment scripts (not part of the project)
PLAN.md
tools/experiments.py

# Build artefacts
build/
dist/
.vercel
