# Copy to .env and fill in. .env is gitignored.

# LLM provider — used only at the LLM touchpoints (English -> ChangeRequest in,
# result -> English out, AND build-time easement-text translation for the
# routeing module). The LLM NEVER computes a fare and NEVER decides validity
# at runtime; easement translation runs offline via
# `python -m src.routeing.translator` and its output is cached in
# data/easement_predicates.json.
#
# Uses Z.AI's OpenAI-compatible endpoint (api.z.ai/api/paas/v4) with the
# glm-4.6 model. See src/llm/zai.py.
ZAI_API_KEY=

# Legacy Anthropic key (unused). Left declared for any downstream tools
# that still expect the ANTHROPIC_API_KEY env var name.
ANTHROPIC_API_KEY=

# Fetch.ai uAgent (Mailbox, never Hosted). Built last, thin wrapper.
# Seed = any long random string; gives the agent a stable Agentverse address
# across restarts. Unset ⇒ uagents generates a local identity.
FETCH_AI_AGENT_SEED=
# Where the agent finds the Meridian API (src/agent/fares_agent.py).
# MERIDIAN_API_URL=http://127.0.0.1:8000

# Path to the RDG DTD fares feed zip. Kept under data/ which is gitignored.
FEED_PATH=data/RJFAF.zip

# NRDP (National Rail Data Portal) — used by src/perf/hsp.py for the HSP
# serviceMetrics endpoint (Historic Service Performance). Sign up at
# https://opendata.nationalrail.co.uk/ and tick the HSP subscription.
# Same credentials work for the fares + timetable feed downloads.
NRDP_EMAIL=
NRDP_PASSWORD=

# Optional override for tests / mocks. Leave unset for production.
# HSP_BASE_URL=https://hsp-prod.rockshore.net
