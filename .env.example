# Copy to .env and fill in. .env is gitignored.

# LLM provider — used only at the two LLM touchpoints (English -> ChangeRequest in,
# result -> English out). The LLM NEVER computes a fare.
ANTHROPIC_API_KEY=

# Fetch.ai uAgent (Mailbox, never Hosted). Built last, thin wrapper.
FETCH_AI_AGENT_KEY=

# Path to the RDG DTD fares feed zip. Kept under data/ which is gitignored.
FEED_PATH=data/RJFAF.zip

# NRDP (National Rail Data Portal) — used by src/perf/hsp.py for the HSP
# serviceMetrics endpoint (Historic Service Performance). Sign up at
# https://opendata.nationalrail.co.uk/ and tick the HSP subscription.
# Same credentials work for the fares + timetable feed downloads.
NRDP_EMAIL=
NRDP_PASSWORD=

# Optional override for tests / mocks. Leave unset for production.
# HSP_BASE_URL=https://hsp-prod.rockshore.net
